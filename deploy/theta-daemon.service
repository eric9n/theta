[Unit]
Description=Theta Routing Proxy Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=%h
Environment=HOME=%h
Environment=RUST_LOG=info
EnvironmentFile=-%h/.config/theta/config.env
EnvironmentFile=-%h/.config/theta/capture-signals.env
ExecStart=/usr/local/bin/theta-daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
