[Unit]
Description=Theta Routing Proxy Daemon
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/theta
EnvironmentFile=/root/.config/theta/capture-signals.env
ExecStart=/root/theta/target/release/theta-daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
